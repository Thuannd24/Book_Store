# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=*

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgres://user:password@localhost:5432/customer_db

# ── Inter-service URLs ────────────────────────────────────────────────────────
# Used by services.py to call cart-service after registration
CART_SERVICE_URL=http://cart-service:8000
