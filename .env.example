# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookstore
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT / Auth ────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION_MS=86400000

# ── Auth Service ──────────────────────────────────────────────
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
AUTH_SERVICE_URL=http://auth-service:8000
JWT_AUTH_ENABLED=false

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_URL=amqp://bookstore:bookstore123@rabbitmq:5672/

# ── API Gateway ───────────────────────────────────────────────
API_GATEWAY_PORT=8080

# ── Service Ports ─────────────────────────────────────────────
STAFF_SERVICE_PORT=8093
MANAGER_SERVICE_PORT=8094
CUSTOMER_SERVICE_PORT=8083
CATALOG_SERVICE_PORT=8084
BOOK_SERVICE_PORT=8085
CART_SERVICE_PORT=8086
ORDER_SERVICE_PORT=8087
SHIP_SERVICE_PORT=8088
PAY_SERVICE_PORT=8089
COMMENT_RATE_SERVICE_PORT=8090
RECOMMENDER_AI_SERVICE_PORT=8091
AUTH_SERVICE_PORT=8092

# ── Payment Gateway ───────────────────────────────────────────
PAYMENT_GATEWAY_API_KEY=your_payment_key_here

# ── AI / Recommender ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
